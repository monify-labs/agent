# Monify Agent Environment Configuration
# This file should be placed at: /etc/monify/.env

# ============================================
# REQUIRED
# ============================================

# Authentication token from Monify platform
# Get your token from: https://dash.monify.cloud
TOKEN_DEVICE=your_token_here

# ============================================
# OPTIONAL
# ============================================

# Monify API server URL
# Default: https://api.monify.cloud/v1/agent/metrics
MONIFY_SERVER_URL=https://api.monify.cloud/v1/agent/metrics

# Collection interval (how often to send metrics)
# Examples: "30s", "1m", "5m"
# Default: 30s
MONIFY_COLLECTION_INTERVAL=30s

# Log level
# Options: debug, info, warn, error
# Default: info
MONIFY_LOG_LEVEL=info
